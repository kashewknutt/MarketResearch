{
  "name": "northstar",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "dev:data": "MARKET_RESEARCH_DATA_DIR=./data next dev",
    "electron:dev": "concurrently -k \"MARKET_RESEARCH_DATA_DIR=./data next dev -p 3847\" \"wait-on http://127.0.0.1:3847 && MARKET_RESEARCH_DATA_DIR=./data ELECTRON_DEV_URL=http://127.0.0.1:3847 node scripts/run-electron.cjs .\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "tsx scripts/db-push-safe.ts",
    "db:push:raw": "drizzle-kit push",
    "backfill:supabase": "tsx scripts/backfill-supabase.ts",
    "org:rename-columns": "tsx scripts/rename-user-id-to-org-id.ts",
    "org:seed-valnee": "tsx scripts/seed-valnee-org.ts",
    "test:projection": "tsx src/lib/research/__tests__/projection-engine.test.ts",
    "postinstall": "npm rebuild better-sqlite3 || true"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.7",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "snoowrap": "^1.23.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "better-sqlite3": "^12.10.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
